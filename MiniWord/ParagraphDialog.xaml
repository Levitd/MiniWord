<Window x:Class="MiniWord.ParagraphDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paragraph" Height="380" Width="450" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <GroupBox x:Name="MainGroup" Header="Indentation &amp; Spacing" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="LeftIndentLabel" Content="Left indent (pt):" />
                        <TextBox x:Name="LeftIndentBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="RightIndentLabel" Content="Right indent (pt):" />
                        <TextBox x:Name="RightIndentBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="FirstLineIndentLabel" Content="First line indent (pt):" />
                        <TextBox x:Name="FirstLineIndentBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="LineSpacingLabel" Content="Line spacing (pt):" />
                        <TextBox x:Name="LineSpacingBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="SpaceBeforeLabel" Content="Space before (pt):" />
                        <TextBox x:Name="SpaceBeforeBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="SpaceAfterLabel" Content="Space after (pt):" />
                        <TextBox x:Name="SpaceAfterBox" Grid.Column="1" Text="0" VerticalContentAlignment="Center" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="0,0,5,0" Click="OK_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
