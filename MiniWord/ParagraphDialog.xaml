<Window x:Class="MiniWord.ParagraphDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paragraph" Height="380" Width="470" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <GroupBox x:Name="MainGroup" Header="Indentation &amp; Spacing" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="LeftIndentLabel" Content="Left indent (pt):" />
                        <Slider x:Name="LeftIndentSlider" Grid.Column="1" Minimum="0" Maximum="200" VerticalAlignment="Center" />
                        <TextBlock x:Name="LeftIndentValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="RightIndentLabel" Content="Right indent (pt):" />
                        <Slider x:Name="RightIndentSlider" Grid.Column="1" Minimum="0" Maximum="200" VerticalAlignment="Center" />
                        <TextBlock x:Name="RightIndentValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="FirstLineIndentLabel" Content="First line indent (pt):" />
                        <Slider x:Name="FirstLineIndentSlider" Grid.Column="1" Minimum="0" Maximum="100" VerticalAlignment="Center" />
                        <TextBlock x:Name="FirstLineIndentValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="LineSpacingLabel" Content="Line spacing (pt):" />
                        <Slider x:Name="LineSpacingSlider" Grid.Column="1" Minimum="0" Maximum="72" VerticalAlignment="Center" />
                        <TextBlock x:Name="LineSpacingValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="SpaceBeforeLabel" Content="Space before (pt):" />
                        <Slider x:Name="SpaceBeforeSlider" Grid.Column="1" Minimum="0" Maximum="72" VerticalAlignment="Center" />
                        <TextBlock x:Name="SpaceBeforeValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Label x:Name="SpaceAfterLabel" Content="Space after (pt):" />
                        <Slider x:Name="SpaceAfterSlider" Grid.Column="1" Minimum="0" Maximum="72" VerticalAlignment="Center" />
                        <TextBlock x:Name="SpaceAfterValue" Grid.Column="2" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="0,0,5,0" Click="OK_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
