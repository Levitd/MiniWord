<Window x:Class="MiniWord.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="280" Width="420" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="FontLabel" Content="Default font:" VerticalAlignment="Center" />
                <ComboBox x:Name="FontCombo" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="SizeLabel" Content="Default font size:" VerticalAlignment="Center" />
                <ComboBox x:Name="SizeCombo" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="LangLabel" Content="Language:" VerticalAlignment="Center" />
                <ComboBox x:Name="LangCombo" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <TextBlock x:Name="NoteText" Margin="5,12,0,0" Foreground="Gray" FontSize="11"
                       Text="Language is applied immediately." />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="0,0,5,0" Click="OK_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
