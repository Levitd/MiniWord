<Window x:Class="MiniWord.StartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniWord" Height="420" Width="520" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="Assets/logo.png" Width="44" Height="44" Margin="0,0,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center" />
            <TextBlock Text="MiniWord" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="RecentLabel" Grid.Row="1" Text="Recent files:" FontWeight="SemiBold" Margin="2,0,0,6" />

        <ListBox x:Name="RecentList" Grid.Row="2" BorderBrush="#DDD"
                 MouseDoubleClick="RecentList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock Text="{Binding FileName}" FontSize="14" />
                        <TextBlock Text="{Binding FullPath}" FontSize="11" Foreground="Gray" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenSelectedButton" Content="Open" Width="110" Height="32" Margin="0,0,8,0"
                    IsDefault="True" Click="OpenSelected_Click" />
            <Button x:Name="BrowseButton" Content="Open other..." Width="120" Height="32" Margin="0,0,8,0"
                    Click="Browse_Click" />
            <Button x:Name="NewButton" Content="New document" Width="140" Height="32"
                    IsCancel="True" Click="New_Click" />
        </StackPanel>
    </Grid>
</Window>
