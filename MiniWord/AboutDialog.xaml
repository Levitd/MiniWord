<Window x:Class="MiniWord.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About MiniWord" Height="320" Width="420" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="20">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Image Source="Assets/logo.png" Width="56" Height="56" Margin="0,0,14,0"
                       RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MiniWord" FontSize="24" FontWeight="Bold" />
                    <TextBlock x:Name="DescriptionText" Foreground="Gray" />
                </StackPanel>
            </StackPanel>

            <Grid Margin="4,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="26" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="VersionLabel" Text="Version:" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText" Grid.Column="1" />

                <TextBlock x:Name="ReleaseDateLabel" Grid.Row="1" Text="Release date:" FontWeight="SemiBold" />
                <TextBlock x:Name="ReleaseDateText" Grid.Row="1" Grid.Column="1" />

                <TextBlock x:Name="AuthorLabel" Grid.Row="2" Text="Author:" FontWeight="SemiBold" />
                <TextBlock x:Name="AuthorText" Grid.Row="2" Grid.Column="1" Text="Levitd" />

                <TextBlock Grid.Row="3" Text="GitHub:" FontWeight="SemiBold" />
                <TextBlock Grid.Row="3" Grid.Column="1">
                    <Hyperlink NavigateUri="https://github.com/Levitd/MiniWord" RequestNavigate="Link_RequestNavigate">
                        github.com/Levitd/MiniWord
                    </Hyperlink>
                </TextBlock>
            </Grid>

            <Button x:Name="OkButton" Content="OK" Width="80" Height="30"
                    HorizontalAlignment="Right" Margin="0,25,0,0" IsDefault="True" IsCancel="True" Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>
