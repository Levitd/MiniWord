<Window x:Class="MiniWord.HyperlinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Insert Hyperlink" Height="180" Width="440" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="TextLabel" Content="Text to display:" VerticalAlignment="Center" />
                <TextBox x:Name="TextBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="UrlLabel" Content="Address (URL):" VerticalAlignment="Center" />
                <TextBox x:Name="UrlBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="0,0,5,0" Click="OK_Click" IsDefault="True" />
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" Click="Cancel_Click" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
