<Window x:Class="MiniWord.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available" Height="380" Width="560" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Image Source="Assets/logo.png" Width="40" Height="40" Margin="0,0,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Top" />
            <TextBlock x:Name="HeadlineText" TextWrapping="Wrap" VerticalAlignment="Center"
                       FontSize="14" Width="380" />
        </StackPanel>

        <TextBlock x:Name="WhatsNewLabel" Grid.Row="1" Text="What's new:" FontWeight="SemiBold" Margin="0,4,0,4" />

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <TextBlock x:Name="NotesText" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,12,0,0">
            <TextBlock x:Name="ProgressLabel" Text="Downloading update..." Margin="0,0,0,4" />
            <ProgressBar x:Name="DownloadProgress" Height="18" Minimum="0" Maximum="1" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="UpdateButton" Content="Update now" Width="120" Height="32" Margin="0,0,8,0"
                    IsDefault="True" Click="Update_Click" />
            <Button x:Name="BackgroundButton" Content="Download in background" Width="180" Height="32" Margin="0,0,8,0"
                    Click="Background_Click" />
            <Button x:Name="LaterButton" Content="Later" Width="90" Height="32"
                    IsCancel="True" Click="Later_Click" />
        </StackPanel>
    </Grid>
</Window>
