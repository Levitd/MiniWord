<Window x:Class="MiniWord.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find and Replace" Height="200" Width="440" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="FindLabel" Content="Find what:" VerticalAlignment="Center" />
                <TextBox x:Name="FindBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <Grid x:Name="ReplaceRow" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="ReplaceLabel" Content="Replace with:" VerticalAlignment="Center" />
                <TextBox x:Name="ReplaceBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <CheckBox x:Name="MatchCaseCheck" Content="Match case" Margin="5,12,0,0" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="FindNextButton" Content="Find Next" Width="90" Height="30" Margin="0,0,5,0" Click="FindNext_Click" IsDefault="True" />
                <Button x:Name="ReplaceButton" Content="Replace" Width="90" Height="30" Margin="0,0,5,0" Click="Replace_Click" />
                <Button x:Name="ReplaceAllButton" Content="Replace All" Width="90" Height="30" Margin="0,0,5,0" Click="ReplaceAll_Click" />
                <Button x:Name="CloseButton" Content="Close" Width="70" Height="30" Click="Close_Click" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
