<Window x:Class="MiniWord.HeaderFooterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Header and Footer" Height="300" Width="470" ResizeMode="NoResize"
        Background="White" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <StackPanel>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="HeaderLabel" Content="Header text:" VerticalAlignment="Center" />
                <TextBox x:Name="HeaderBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="FooterLabel" Content="Footer text:" VerticalAlignment="Center" />
                <TextBox x:Name="FooterBox" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <CheckBox x:Name="PageNumbersCheck" Content="Page numbers" Margin="5,15,0,0" />

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Label x:Name="PositionLabel" Content="Number position:" VerticalAlignment="Center" />
                <ComboBox x:Name="PositionCombo" Grid.Column="1" Height="26" VerticalContentAlignment="Center" />
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="0,0,5,0" Click="OK_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" Click="Cancel_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
